#!/usr/bin/env bash
# notify: desktop notifier for terminal agents/tools running in tmux/WezTerm.
#
# Subcommands:
#   notify send [opts]            post a notification (see options below)
#   notify blocker [message]      urgent alert: sound + banner, bypasses focus check
#   notify claude-hook <event>    Claude Code hook adapter; reads hook JSON on stdin
#   notify codex-hook [json]      Codex CLI notify adapter; takes its JSON argument
#   notify focus <target>         jump to tmux target + bring WezTerm to front
#   notify focus-last             jump to the most recently notified target
#   notify target                 print the tmux target this process resolves to
#   notify test                   send a test blocker notification
#
# send options:
#   --event <stop|input|blocker>  kind of notification (default stop)
#   --app <name>                  who is notifying, used in the title (or $NOTIFY_APP)
#   --title / --message / --sound overrides
#   --force                       notify even if the target pane is focused
#
# Click-to-jump: banners are posted via terminal-notifier with -execute wired to
# `notify focus <target>`, so clicking the banner switches the tmux client to the
# originating session:window.pane and activates WezTerm.
#
# Target resolution order: $NOTIFY_TARGET, $TMUX_PANE, then a scan for the tmux
# pane whose cwd matches this process's project dir (background jobs have no
# TMUX_PANE; worktree paths under .claude/worktrees resolve to the repo).
#
# On hosts without terminal-notifier (e.g. Linux over SSH), events are forwarded
# as "EVENT|host:target" lines to 127.0.0.1:$NOTIFY_PORT, where the Mac's
# notify listener (reverse SSH tunnel, see listener.sh) shows the banner.
#
# Env knobs:
#   NOTIFY_APP       default app label for titles (e.g. "Claude blocked")
#   NOTIFY_TARGET    explicit tmux target (session:window.pane)
#   NOTIFY_PORT      remote-forward port (default 9876)
#   NOTIFY_VOLUME    afplay volume 0.0-1.0 (default 0.8)
#   NOTIFY_SOUND_STOP / _INPUT / _BLOCKER
#                    system sound name or "none" (defaults: none/none/Basso)
#   NOTIFY_DEBUG     log to $XDG_STATE_HOME/notify/debug.log
set -u

# Click handlers and hooks run with a minimal env; make sure brew tools resolve.
PATH="/opt/homebrew/bin:/usr/local/bin:$PATH"

SELF="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/$(basename "${BASH_SOURCE[0]}")"
STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/notify"
PORT="${NOTIFY_PORT:-9876}"
VOLUME="${NOTIFY_VOLUME:-0.8}"
WEZTERM_BUNDLE="com.github.wez.wezterm"

TMUX_BIN=$(command -v tmux || true)

log() {
  [ -n "${NOTIFY_DEBUG:-}" ] || return 0
  mkdir -p "$STATE_DIR"
  printf '%s %s\n' "$(date '+%F %T')" "$*" >>"$STATE_DIR/debug.log"
}

# ---------------------------------------------------------------- target logic

pane_target_of() {
  [ -n "$TMUX_BIN" ] || return 1
  "$TMUX_BIN" display-message -p -t "$1" '#{session_name}:#{window_index}.#{pane_index}' 2>/dev/null
}

# Agent panes show recognizable commands: the Claude CLI appears as a bare
# version string ("2.1.198"), "claude", or "node"; Codex as "codex".
resolve_target() {
  if [ -n "${NOTIFY_TARGET:-}" ]; then
    printf '%s\n' "$NOTIFY_TARGET"
    return 0
  fi
  if [ -n "${TMUX_PANE:-}" ]; then
    pane_target_of "$TMUX_PANE" && return 0
  fi
  [ -n "$TMUX_BIN" ] || return 1
  # Match panes at our cwd or our project root (git toplevel, worktrees
  # resolved to the main repo) so resolution survives cd'ing into subdirs.
  local dir="$PWD" repo ver=""
  repo=$(git -C "$PWD" rev-parse --show-toplevel 2>/dev/null) || repo="$dir"
  case "$repo" in
    */.claude/worktrees/*) repo="${repo%%/.claude/worktrees/*}" ;;
  esac
  # Claude panes show the CLI version as their command; matching our own
  # version disambiguates multiple Claude panes in the same directory.
  [ -n "${CLAUDE_CODE_EXECPATH:-}" ] && ver=$(basename "$CLAUDE_CODE_EXECPATH")
  "$TMUX_BIN" list-panes -a \
    -F '#{window_activity}|#{pane_current_path}|#{pane_current_command}|#{session_name}:#{window_index}.#{pane_index}' \
    2>/dev/null | awk -F'|' -v d="$dir" -v r="$repo" -v v="$ver" '
      $2 == d || $2 == r {
        score = $1
        if ($3 ~ /^([0-9]+\.[0-9.]+|claude|codex|node)$/) score += 1e12
        if (v != "" && $3 == v) score += 1e13
        if (score > best) { best = score; target = $4 }
      }
      END { if (target) print target; else exit 1 }'
}

frontmost_is_wezterm() {
  command -v lsappinfo >/dev/null 2>&1 || return 1
  lsappinfo info -only bundleid "$(lsappinfo front 2>/dev/null)" 2>/dev/null |
    grep -qi "$WEZTERM_BUNDLE"
}

# User is already looking at this pane: active pane of an attached session while
# WezTerm is the frontmost app.
target_is_focused() {
  local target="$1" info
  [ -n "$target" ] && [ -n "$TMUX_BIN" ] || return 1
  info=$("$TMUX_BIN" display-message -p -t "$target" \
    '#{pane_active}#{window_active}#{?session_attached,1,0}' 2>/dev/null) || return 1
  [ "$info" = "111" ] && frontmost_is_wezterm
}

remember_target() {
  [ -n "$1" ] || return 0
  mkdir -p "$STATE_DIR"
  printf '%s\n' "$1" >"$STATE_DIR/last-target"
}

# ------------------------------------------------------------------ delivery

play_sound() {
  local sound="$1" file
  [ -n "$sound" ] && [ "$sound" != "none" ] || return 0
  command -v afplay >/dev/null 2>&1 || return 0
  case "$sound" in
    /*) file="$sound" ;;
    *)  file="/System/Library/Sounds/${sound}.aiff" ;;
  esac
  [ -f "$file" ] || return 0
  (afplay -v "$VOLUME" "$file" >/dev/null 2>&1 &)
}

post_banner() {
  local title="$1" message="$2" subtitle="$3" group="$4" target="$5" wezpane="$6"
  if command -v terminal-notifier >/dev/null 2>&1; then
    local args=(-title "$title" -message "$message" -group "$group")
    [ -n "$subtitle" ] && args+=(-subtitle "$subtitle")
    if [ -n "$target" ]; then
      local safe=${target//\'/\'\\\'\'}
      args+=(-execute "'$SELF' focus '$safe' ${wezpane:-}")
    else
      args+=(-activate "$WEZTERM_BUNDLE")
    fi
    terminal-notifier "${args[@]}" >/dev/null 2>&1 && return 0
  fi
  command -v osascript >/dev/null 2>&1 || return 1
  osascript -e 'on run argv
    display notification (item 2 of argv) with title (item 1 of argv)
  end run' "$title" "$message" >/dev/null 2>&1 || true
}

forward_remote() {
  local event="$1" target="$2" host label
  command -v nc >/dev/null 2>&1 || return 1
  host=$(hostname -s 2>/dev/null || hostname || echo remote)
  label="$host"
  [ -n "$target" ] && label="$host:$target"
  printf '%s|%s\n' "$event" "$label" | nc -w1 -q0 127.0.0.1 "$PORT" >/dev/null 2>&1 ||
    printf '%s|%s\n' "$event" "$label" | nc -w1 127.0.0.1 "$PORT" >/dev/null 2>&1 || true
}

do_send() {
  local event="stop" app="${NOTIFY_APP:-}" title="" message="" sound="" force=0
  while [ $# -gt 0 ]; do
    case "$1" in
      --event)   event="$2"; shift 2 ;;
      --app)     app="$2"; shift 2 ;;
      --title)   title="$2"; shift 2 ;;
      --message) message="$2"; shift 2 ;;
      --sound)   sound="$2"; shift 2 ;;
      --force)   force=1; shift ;;
      *) echo "notify send: unknown option $1" >&2; return 2 ;;
    esac
  done

  local target
  target=$(resolve_target || true)
  log "send event=$event app=${app:-none} target=${target:-none} force=$force"

  local bare phrase
  case "$event" in
    input)   bare="Needs input"; phrase="needs input"; sound="${sound:-${NOTIFY_SOUND_INPUT:-none}}" ;;
    blocker) bare="Blocked";     phrase="blocked";     sound="${sound:-${NOTIFY_SOUND_BLOCKER:-Basso}}" ;;
    *)       bare="Done";        phrase="done";        sound="${sound:-${NOTIFY_SOUND_STOP:-none}}" ;;
  esac
  if [ -z "$title" ]; then
    if [ -n "$app" ]; then title="$app $phrase"; else title="$bare"; fi
  fi

  # No local notifier (e.g. headless Linux): forward to the Mac listener.
  if ! command -v terminal-notifier >/dev/null 2>&1 && ! command -v osascript >/dev/null 2>&1; then
    case "$event" in
      input)   forward_remote Notification "$target" ;;
      blocker) forward_remote Blocker "$target" ;;
      *)       forward_remote Stop "$target" ;;
    esac
    return 0
  fi

  if [ "$force" -ne 1 ] && target_is_focused "${target:-}"; then
    log "send skipped: target focused"
    return 0
  fi

  play_sound "$sound"
  local project subtitle="" wezpane=""
  project=$(basename "${CLAUDE_PROJECT_DIR:-$PWD}")
  [ -n "${target:-}" ] && subtitle="$project — $target"
  # WEZTERM_PANE pins the right WezTerm window on click, but background jobs
  # inherit a stale value from the daemon's spawner — only trust it in-pane.
  [ -n "${TMUX_PANE:-}" ] && wezpane="${WEZTERM_PANE:-}"
  post_banner "$title" "${message:-$project}" "$subtitle" \
    "notify-${target:-${app:-local}}" "${target:-}" "$wezpane"
  remember_target "${target:-}"
}

# --------------------------------------------------------------------- focus

do_focus() {
  local target="$1" wezpane="${2:-}"
  [ -n "$target" ] || return 1
  if [ -n "$TMUX_BIN" ]; then
    local client
    client=$("$TMUX_BIN" list-clients -F '#{client_activity} #{client_name}' 2>/dev/null |
      sort -rn | head -1 | cut -d' ' -f2-)
    if [ -n "$client" ]; then
      "$TMUX_BIN" switch-client -c "$client" -t "$target" 2>/dev/null || true
    fi
    "$TMUX_BIN" select-window -t "$target" 2>/dev/null || true
    "$TMUX_BIN" select-pane -t "$target" 2>/dev/null || true
  fi
  if [ -n "$wezpane" ] && command -v wezterm >/dev/null 2>&1; then
    wezterm cli activate-pane --pane-id "$wezpane" >/dev/null 2>&1 || true
  fi
  if command -v open >/dev/null 2>&1; then
    open -b "$WEZTERM_BUNDLE" 2>/dev/null ||
      osascript -e "tell application id \"$WEZTERM_BUNDLE\" to activate" >/dev/null 2>&1 || true
  fi
}

do_focus_last() {
  [ -f "$STATE_DIR/last-target" ] || return 1
  do_focus "$(cat "$STATE_DIR/last-target")"
}

# ------------------------------------------------------------------- adapters

# Claude Code hook entry (Stop/Notification hooks in settings.json). Reads the
# hook's JSON payload from stdin and uses its `message` field as the banner
# body. Skips stop-hook continuations and subagent events to avoid duplicates.
do_claude_hook() {
  local event="${1:-Stop}" payload="" message=""
  [ -t 0 ] || payload=$(cat 2>/dev/null || true)
  if [ -n "$payload" ] && command -v jq >/dev/null 2>&1; then
    case "$(printf '%s' "$payload" | jq -r '[.stop_hook_active // false, (.agent_id // "" | length > 0)] | @csv' 2>/dev/null)" in
      *true*) return 0 ;;
    esac
    message=$(printf '%s' "$payload" | jq -r '.message // empty' 2>/dev/null || true)
  fi
  NOTIFY_APP="${NOTIFY_APP:-Claude}"
  case "$event" in
    Notification) do_send --event input ${message:+--message "$message"} ;;
    *)            do_send --event stop ${message:+--message "$message"} ;;
  esac
}

# Codex CLI adapter: in ~/.codex/config.toml set
#   notify = ["/Users/<you>/.config/scripts/notify/notify", "codex-hook"]
# Codex invokes it with one JSON argument, e.g. type "agent-turn-complete".
do_codex_hook() {
  local payload="${1:-}" type="" message=""
  if [ -n "$payload" ] && command -v jq >/dev/null 2>&1; then
    type=$(printf '%s' "$payload" | jq -r '.type // empty' 2>/dev/null || true)
    message=$(printf '%s' "$payload" | jq -r '.["last-assistant-message"] // empty' 2>/dev/null | head -c 200 || true)
  fi
  case "$type" in
    agent-turn-complete|"") NOTIFY_APP="${NOTIFY_APP:-Codex}" do_send --event stop ${message:+--message "$message"} ;;
    *) return 0 ;;
  esac
}

# ---------------------------------------------------------------------- main

case "${1:-}" in
  send)        shift; do_send "$@" ;;
  blocker)     shift; do_send --event blocker --force ${1:+--message "$1"} ;;
  claude-hook) shift; do_claude_hook "$@" ;;
  codex-hook)  shift; do_codex_hook "$@" ;;
  focus)       shift; do_focus "${1:-}" "${2:-}" ;;
  focus-last)  do_focus_last ;;
  target)      resolve_target ;;
  test)        do_send --event blocker --force --message "Test notification — click to jump to this pane" ;;
  *)
    awk 'NR > 1 && !/^#/ { exit } NR > 1 { sub(/^# ?/, ""); print }' "$SELF"
    exit 2
    ;;
esac
