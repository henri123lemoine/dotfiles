{
  "cleanupPeriodDays": 36500,
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "128000",
    "CLAUDE_CODE_SUBAGENT_MODEL": "inherit",
    "CLAUDE_CODE_NO_FLICKER": "1"
  },
  "includeCoAuthoredBy": true,
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Edit",
      "Write",
      "MultiEdit",
      "Glob",
      "Grep",
      "Task",
      "WebFetch",
      "WebSearch",
      "mcp__exa__web_search_exa",
      "mcp__linear-server__list_issues",
      "Bash(curl *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(~/.aws/**)"
    ],
    "ask": [
      "Bash(gh pr create *)",
      "Bash(gh pr create)",
      "Bash(gh pr merge *)",
      "Bash(gh pr merge)",
      "Bash(gh pr review *)",
      "Bash(gh pr close *)",
      "Bash(gh issue create *)",
      "Bash(gh issue comment *)",
      "Bash(gh release *)",
      "Bash(gh api *-X *)",
      "Bash(gh api *--method *)",
      "Bash(gh api *-f *)",
      "Bash(gh api *-F *)",
      "Bash(gh api *--field *)",
      "Bash(gh api *--raw-field *)",
      "Bash(gh api *--input *)",
      "Bash(rm -rf *)",
      "Bash(rm -r *)",
      "Bash(rm -fr *)",
      "Bash(git push --force-with-lease *)",
      "Bash(git push --force-with-lease)",
      "Bash(git push --force *)",
      "Bash(git push --force)",
      "Bash(git push -f *)",
      "Bash(git push -f)",
      "Bash(git reset --hard *)",
      "Bash(git reset --hard)",
      "Bash(git checkout -- *)",
      "Bash(git clean *)",
      "Bash(git branch -D *)",
      "Bash(git stash drop *)",
      "Bash(git stash clear)",
      "Bash(sudo *)",
      "Bash(chmod *)",
      "Bash(*| sh)",
      "Bash(*| sh *)",
      "Bash(*| bash)",
      "Bash(*| bash *)"
    ],
    "defaultMode": "auto"
  },
  "model": "claude-fable-5[1m]",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hook_scripts/gh_pr_draft_gate.py"
          }
        ]
      }
    ],
    "PostToolUse": [],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hook_scripts/notify_pane.sh Notification"
          }
        ]
      }
    ],
    "UserPromptSubmit": [],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hook_scripts/notify_pane.sh Stop"
          }
        ]
      }
    ],
    "SubagentStop": [],
    "PreCompact": [],
    "SessionStart": []
  },
  "worktree": {
    "baseRef": "fresh",
    "bgIsolation": "none"
  },
  "statusLine": {
    "type": "command",
    "command": "jq -r '[.model.display_name // \"Claude\", ((.workspace.current_dir // .cwd // \"\") | split(\"/\") | last), ((.context_window.used_percentage // 0 | floor | tostring) + \"% ctx\"), (if ((.cost.total_cost_usd // 0) > 0) then (\"$\" + (((.cost.total_cost_usd // 0) * 100 | round / 100) | tostring)) else empty end), (if .rate_limits.five_hour.used_percentage then (\"5h \" + ((.rate_limits.five_hour.used_percentage | floor | tostring) + \"%\")) else empty end)] | join(\" | \")'",
    "padding": 0
  },
  "enabledPlugins": {
    "document-skills@anthropic-agent-skills": true,
    "code-review@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "greptile@claude-plugins-official": false,
    "clangd-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "astral@astral-sh": true,
    "vercel@claude-plugins-official": true,
    "slack@claude-plugins-official": true,
    "codex@openai-codex": true
  },
  "extraKnownMarketplaces": {
    "astral-sh": {
      "source": {
        "source": "github",
        "repo": "astral-sh/claude-code-plugins"
      }
    },
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    }
  },
